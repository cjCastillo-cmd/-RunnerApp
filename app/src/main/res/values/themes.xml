<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal Runner App — estilo Nike Run Club oscuro -->
    <style name="Theme.RunnerApp" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/volt</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/volt</item>
        <item name="colorOnPrimaryContainer">@color/black</item>
        <item name="colorSecondary">@color/volt</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Estilo para dropdowns -->
    <style name="RunnerDropdownLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- Estilo para inputs rectangulares sin radius -->
    <style name="RunnerInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">0dp</item>
        <item name="boxCornerRadiusTopEnd">0dp</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- Boton volt principal -->
    <style name="RunnerButton.Volt" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/volt</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- Boton texto (link) -->
    <style name="RunnerButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">@color/volt_20</item>
    </style>

    <!-- Boton rojo (logout/cancelar) -->
    <style name="RunnerButton.Red" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/red</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <!-- Boton outline -->
    <style name="RunnerButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <!-- Texto base -->
    <style name="RunnerText" parent="">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Texto estilo Bebas Neue para numeros grandes -->
    <style name="RunnerText.Display">
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Avatar circular -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Bottom navigation -->
    <style name="RunnerBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>

</resources>
