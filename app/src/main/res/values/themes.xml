<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal RunBoost — Soporta claro y oscuro -->
    <style name="Theme.RunnerApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/accent_on</item>
        <item name="colorPrimaryContainer">@color/accent</item>
        <item name="colorOnPrimaryContainer">@color/accent_on</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/accent_on</item>
        <item name="colorSurface">@color/background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Input con bordes redondeados -->
    <style name="RunnerInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- Dropdown con bordes redondeados -->
    <style name="RunnerDropdownLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>

    <!-- Boton principal verde -->
    <style name="RunnerButton.Volt" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:maxWidth">420dp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Boton texto (link) -->
    <style name="RunnerButton.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">@color/accent_20</item>
    </style>

    <!-- Boton rojo (logout/eliminar) -->
    <style name="RunnerButton.Red" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/red</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxWidth">420dp</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- Boton outline -->
    <style name="RunnerButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:maxWidth">420dp</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- Avatar circular -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
