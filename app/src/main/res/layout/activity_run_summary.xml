<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Titulo celebratorio -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_run_completed"
        android:textSize="13sp"
        android:textColor="@color/accent"
        android:letterSpacing="0.3"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp" />

    <!-- KM grande -->
    <TextView
        android:id="@+id/tvKm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_km"
        android:textSize="96sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:includeFontPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvKmLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_kilometers"
        android:textSize="16sp"
        android:textColor="@color/accent"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toBottomOf="@id/tvKm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Fecha -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/default_date"
        android:textSize="13sp"
        android:textColor="@color/text_tertiary"
        app:layout_constraintTop_toBottomOf="@id/tvKmLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Stats row -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
                android:baselineAligned="false"
        app:layout_constraintTop_toBottomOf="@id/tvDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <!-- Tiempo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_duration"
                android:textSize="28sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_time"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <!-- Calorias -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginHorizontal="3dp">

            <TextView
                android:id="@+id/tvCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_zero"
                android:textSize="28sp"
                android:textColor="@color/orange"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_kcal"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <!-- Ritmo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/surface"
            android:padding="16dp"
            android:layout_marginStart="6dp">

            <TextView
                android:id="@+id/tvPace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_pace"
                android:textSize="28sp"
                android:textColor="@color/blue"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_min_km"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.2" />
        </LinearLayout>

    </LinearLayout>

    <!-- Boton compartir -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShare"
        style="@style/RunnerButton.Volt"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_share"
        app:layout_constraintBottom_toTopOf="@id/btnClose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Boton cerrar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        style="@style/RunnerButton.Outline"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_close"
        android:textColor="@color/text_secondary"
        app:strokeColor="@color/border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>