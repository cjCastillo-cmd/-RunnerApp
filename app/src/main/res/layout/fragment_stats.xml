<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="100dp">

            <!-- Titulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_your_stats"
                android:textSize="32sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:background="@color/accent"
                android:layout_marginTop="8dp" />

            <!-- ===== BLOQUE SEMANAL ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_this_week"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="28dp" />

            <!-- Stats semana - fila 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- KM semana -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_distance"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvWeekKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero_decimal"
                        android:textSize="40sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_km"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <!-- Diferencia vs semana pasada -->
                    <TextView
                        android:id="@+id/tvWeekKmDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_km"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Carreras semana -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_runs"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvWeekRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="40sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_runs_count"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvWeekRunsDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_zero"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Stats semana - fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- Calorias semana -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_calories"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvWeekKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="40sp"
                        android:textColor="@color/orange"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_kcal"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvWeekKcalDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_kcal"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Ritmo semana -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_avg_pace"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvWeekPace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_pace"
                        android:textSize="40sp"
                        android:textColor="@color/blue"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_min_km"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvWeekPaceDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_pace"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== BLOQUE MENSUAL ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_this_month"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="28dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- KM mes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_distance"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvMonthKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero_decimal"
                        android:textSize="40sp"
                        android:textColor="@color/accent"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_km"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonthKmDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_km"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Carreras mes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_runs"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvMonthRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="40sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_runs_count"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonthRunsDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_zero"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Mes fila 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <!-- Calorias mes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_calories"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvMonthKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="40sp"
                        android:textColor="@color/orange"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_kcal"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonthKcalDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_kcal"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Ritmo mes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_avg_pace"
                        android:textSize="10sp"
                        android:textColor="@color/text_tertiary"
                        android:letterSpacing="0.2" />

                    <TextView
                        android:id="@+id/tvMonthPace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_pace"
                        android:textSize="40sp"
                        android:textColor="@color/blue"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_min_km"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvMonthPaceDiff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_diff_pace"
                        android:textSize="12sp"
                        android:textColor="@color/green"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Mensaje sin datos -->
            <TextView
                android:id="@+id/tvNoStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_stats_message"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:visibility="gone"
                android:layout_marginTop="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>