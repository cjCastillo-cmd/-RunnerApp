<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Mapa en la mitad superior -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.45" />

    <!-- Gradiente sobre el mapa para transicion suave -->
    <View
        android:id="@+id/mapOverlay"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@drawable/gradient_black_top"
        app:layout_constraintBottom_toBottomOf="@id/mapFragment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Panel de estadisticas -->
    <LinearLayout
        android:id="@+id/statsPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/mapFragment"
        app:layout_constraintBottom_toTopOf="@id/buttonsRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Label TIEMPO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_time"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.3" />

        <!-- Timer enorme -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_time_short"
            android:textSize="80sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:includeFontPadding="false" />

        <!-- Fila de stats: KM | KCAL | MIN/KM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <!-- KM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvKm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_km"
                    android:textSize="36sp"
                    android:textColor="@color/accent"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_km"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/border" />

            <!-- KCAL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvKcal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_zero"
                    android:textSize="36sp"
                    android:textColor="@color/orange"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_kcal"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@color/border" />

            <!-- MIN/KM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvPace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_pace"
                    android:textSize="36sp"
                    android:textColor="@color/blue"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_min_km"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Botones FINALIZAR y CANCELAR -->
    <LinearLayout
        android:id="@+id/buttonsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Cancelar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/RunnerButton.Outline"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:textColor="@color/text_secondary"
            app:strokeColor="@color/border"
            android:layout_marginEnd="8dp" />

        <!-- Finalizar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinish"
            style="@style/RunnerButton.Volt"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/btn_finish"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>