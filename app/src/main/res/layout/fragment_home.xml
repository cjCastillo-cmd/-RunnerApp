<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="100dp">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/greeting_default"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.2" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_runner_name"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="2dp" />

            <!-- Hero stat: KM totales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:background="@color/surface"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_distance"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.3" />

                <TextView
                    android:id="@+id/tvTotalKm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_zero_decimal"
                    android:textSize="96sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_km"
                    android:textSize="18sp"
                    android:textColor="@color/volt"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Mini stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Carreras -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/tvTotalRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="32sp"
                        android:textColor="@color/volt"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_runs"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.2" />
                </LinearLayout>

                <!-- Calorias -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginHorizontal="4dp">

                    <TextView
                        android:id="@+id/tvTotalKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_zero"
                        android:textSize="32sp"
                        android:textColor="@color/orange"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_kcal"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.2" />
                </LinearLayout>

                <!-- Ritmo -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/surface"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvAvgPace"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_pace"
                        android:textSize="32sp"
                        android:textColor="@color/blue"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        android:includeFontPadding="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_min_km"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.2" />
                </LinearLayout>

            </LinearLayout>

            <!-- Boton START circular -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center">

                <!-- Glow exterior -->
                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/start_button_glow"
                    android:alpha="0.3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:text="@string/btn_start"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    app:backgroundTint="@color/volt"
                    app:cornerRadius="60dp"
                    app:elevation="8dp" />
            </FrameLayout>

            <!-- Carreras recientes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_recent_runs"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.2"
                android:layout_marginTop="32dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentRuns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp"
                android:overScrollMode="never" />

            <!-- Mensaje vacio -->
            <TextView
                android:id="@+id/tvEmptyRuns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_runs_message"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:lineSpacingExtra="4sp"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>