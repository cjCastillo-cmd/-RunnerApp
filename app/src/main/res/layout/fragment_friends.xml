<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="100dp">

            <!-- Titulo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_social"
                android:textSize="32sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:background="@color/accent"
                android:layout_marginTop="8dp" />

            <!-- ===== CLASIFICACION DEL MES ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_monthly_ranking"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_leaderboard"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:visibility="gone"
                android:layout_marginTop="12dp" />

            <!-- ===== SOLICITUDES PENDIENTES ===== -->
            <TextView
                android:id="@+id/tvRequestsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_pending_requests"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="28dp" />

            <!-- Badge de cantidad -->
            <TextView
                android:id="@+id/tvRequestsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_zero"
                android:textSize="11sp"
                android:textColor="@color/background"
                android:textStyle="bold"
                android:background="@color/accent"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_requests"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:layout_marginTop="12dp" />

            <!-- ===== MIS AMIGOS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_my_friends"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="28dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFriends"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyFriends"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_friends"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:layout_marginTop="12dp" />

            <!-- ===== DESCUBRIR ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_discover"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.3"
                android:layout_marginTop="28dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDiscover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="12dp"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyDiscover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/empty_discover"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:textAlignment="center"
                android:visibility="gone"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>