<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Mapa con la ruta -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.55" />

    <!-- Gradiente -->
    <View
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@drawable/gradient_black_top"
        app:layout_constraintBottom_toBottomOf="@id/mapFragment"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Boton atras -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:icon="@android:drawable/ic_menu_revert"
        app:iconTint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="8dp" />

    <!-- Panel de estadisticas -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/mapFragment"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Fecha -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_date"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:letterSpacing="0.1" />

        <!-- KM grande -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvKm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_km"
                android:textSize="64sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_km_suffix"
                android:textSize="20sp"
                android:textColor="@color/volt"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />
        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <!-- Duracion -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_duration"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_time"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Calorias -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="16dp"
                android:layout_marginHorizontal="3dp">

                <TextView
                    android:id="@+id/tvCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_zero"
                    android:textSize="24sp"
                    android:textColor="@color/orange"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_kcal"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

            <!-- Ritmo -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/surface"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/tvPace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_pace"
                    android:textSize="24sp"
                    android:textColor="@color/blue"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_min_km"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />
            </LinearLayout>

        </LinearLayout>

        <!-- Boton eliminar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/RunnerButton.Red"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_delete_run"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>